# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.

SECRET_KEY=changeme-generate-a-real-key-in-production
DEBUG=True

# Railway provides this automatically when PostgreSQL is added to a project.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Open-Meteo: leave blank for the free dev tier (no key needed).
# Set to https://customer-api.open-meteo.com before Phase 8 go-live.
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OPEN_METEO_API_KEY=

# Phase 4 data sources (all free tier, no keys needed in dev)
OPEN_METEO_SEASONAL_URL=https://seasonal-api.open-meteo.com
OPEN_METEO_SEASONAL_API_KEY=
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com
OPEN_METEO_ARCHIVE_API_KEY=
OPEN_METEO_AIRQUALITY_URL=https://air-quality-api.open-meteo.com
OPEN_METEO_AIRQUALITY_API_KEY=

# Email: console backend prints emails to terminal (safe for local dev).
# Switch to smtp backend and fill in host/credentials before go-live.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=weather@yourdomain.com
ADMIN_EMAIL=adammiros25@gmail.com
